#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="delcal"

usage() {
  cat <<'EOF'
Usage:
  delcal --id "<event-id>"
  delcal --title "<title>" --start "<when>" --end "<when>" [--calendar "<name>"] [--dry-run]
EOF
}

main() {
  local calendar="$DEFAULT_CALENDAR"
  local event_id=""
  local title=""
  local start=""
  local end=""
  local start_year=""
  local start_month=""
  local start_day=""
  local start_hour=""
  local start_minute=""
  local end_year=""
  local end_month=""
  local end_day=""
  local end_hour=""
  local end_minute=""
  local dry_run=0
  local result=""

  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --calendar)
        [[ $# -ge 2 ]] || calendar_die "missing value for --calendar"
        calendar="$2"
        shift 2
        ;;
      --id)
        [[ $# -ge 2 ]] || calendar_die "missing value for --id"
        event_id="$2"
        shift 2
        ;;
      --title)
        [[ $# -ge 2 ]] || calendar_die "missing value for --title"
        title="$2"
        shift 2
        ;;
      --start)
        [[ $# -ge 2 ]] || calendar_die "missing value for --start"
        start="$2"
        shift 2
        ;;
      --end)
        [[ $# -ge 2 ]] || calendar_die "missing value for --end"
        end="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        calendar_die "unknown option: $1"
        ;;
    esac
  done

  if [[ -n "$event_id" ]]; then
    if [[ -n "$title" || -n "$start" || -n "$end" ]]; then
      calendar_die "use either --id or the --title/--start/--end matcher, not both"
    fi
  else
    [[ -n "$title" ]] || calendar_die "missing --title"
    [[ -n "$start" ]] || calendar_die "missing --start"
    [[ -n "$end" ]] || calendar_die "missing --end"
    parse_datetime "$start" start
    parse_datetime "$end" end
  fi

  result="$(
    osascript - "$calendar" "$event_id" "$title" "$dry_run" \
      "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
      "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute" <<'APPLESCRIPT'
on replaceText(inputValue, findValue, replaceValue)
  set originalDelims to AppleScript's text item delimiters
  set AppleScript's text item delimiters to findValue
  set parts to every text item of (inputValue as text)
  set AppleScript's text item delimiters to replaceValue
  set normalizedValue to parts as text
  set AppleScript's text item delimiters to originalDelims
  return normalizedValue
end replaceText

on safeTitle(inputValue)
  set normalizedValue to inputValue as text
  set normalizedValue to my replaceText(normalizedValue, return, " ")
  set normalizedValue to my replaceText(normalizedValue, linefeed, " ")
  set normalizedValue to my replaceText(normalizedValue, tab, " ")
  return normalizedValue
end safeTitle

on run argv
  set calendarName to item 1 of argv
  set targetEventId to item 2 of argv
  set targetTitle to item 3 of argv
  set dryRunValue to item 4 of argv
  set startYear to item 5 of argv
  set startMonth to item 6 of argv
  set startDay to item 7 of argv
  set startHour to item 8 of argv
  set startMinute to item 9 of argv
  set endYear to item 10 of argv
  set endMonth to item 11 of argv
  set endDay to item 12 of argv
  set endHour to item 13 of argv
  set endMinute to item 14 of argv

  tell application "Calendar"
    if targetEventId is not "" then
      set matchedEvents to {}
      repeat with cal in calendars
        set candidateEvents to every event of cal whose id is targetEventId
        if (count of candidateEvents) > 0 then
          set matchedEvents to candidateEvents
          exit repeat
        end if
      end repeat
    else
      set matchingCalendars to every calendar whose name is calendarName
      if (count of matchingCalendars) is 0 then error "Calendar not found: " & calendarName
      set startDate to current date
      set day of startDate to 1
      set year of startDate to startYear as integer
      set month of startDate to startMonth as integer
      set day of startDate to startDay as integer
      set time of startDate to ((startHour as integer) * hours) + ((startMinute as integer) * minutes)
      set seconds of startDate to 0

      set endDate to current date
      set day of endDate to 1
      set year of endDate to endYear as integer
      set month of endDate to endMonth as integer
      set day of endDate to endDay as integer
      set time of endDate to ((endHour as integer) * hours) + ((endMinute as integer) * minutes)
      set seconds of endDate to 0
      set matchedEvents to every event of first item of matchingCalendars whose summary is targetTitle and start date = startDate and end date = endDate
    end if

    set outputText to ""
    repeat with evt in matchedEvents
      set outputText to outputText & (id of evt) & tab & my safeTitle(summary of evt) & linefeed
      if dryRunValue is "0" then delete evt
    end repeat
    return outputText
  end tell
end run
APPLESCRIPT
  )"

  [[ -n "$result" ]] || calendar_die "no matching event found"

  while IFS=$'\t' read -r deleted_id deleted_title; do
    [[ -n "$deleted_id" ]] || continue
    if [[ "$dry_run" -eq 1 ]]; then
      printf 'Matched event: %s [id=%s]\n' "$deleted_title" "$deleted_id"
    else
      printf 'Deleted event: %s [id=%s]\n' "$deleted_title" "$deleted_id"
    fi
  done <<< "$result"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
