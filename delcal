#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="delcal"

usage() {
  cat <<'EOF'
Usage:
  delcal --id "<event-id>"
  delcal --title "<title>" --start "<when>" --end "<when>" [--calendar "<name>"] [--dry-run]
EOF
}

main() {
  local calendar="$DEFAULT_CALENDAR"
  local event_id=""
  local title=""
  local start=""
  local end=""
  local dry_run=0
  local result=""

  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --calendar)
        [[ $# -ge 2 ]] || calendar_die "missing value for --calendar"
        calendar="$2"
        shift 2
        ;;
      --id)
        [[ $# -ge 2 ]] || calendar_die "missing value for --id"
        event_id="$2"
        shift 2
        ;;
      --title)
        [[ $# -ge 2 ]] || calendar_die "missing value for --title"
        title="$2"
        shift 2
        ;;
      --start)
        [[ $# -ge 2 ]] || calendar_die "missing value for --start"
        start="$2"
        shift 2
        ;;
      --end)
        [[ $# -ge 2 ]] || calendar_die "missing value for --end"
        end="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        calendar_die "unknown option: $1"
        ;;
    esac
  done

  if [[ -n "$event_id" ]]; then
    if [[ -n "$title" || -n "$start" || -n "$end" ]]; then
      calendar_die "use either --id or the --title/--start/--end matcher, not both"
    fi
  else
    [[ -n "$title" ]] || calendar_die "missing --title"
    [[ -n "$start" ]] || calendar_die "missing --start"
    [[ -n "$end" ]] || calendar_die "missing --end"
    start="$(parse_datetime_expression "$start")"
    end="$(parse_datetime_expression "$end")"
  fi

  result="$(
    osascript - "$calendar" "$event_id" "$title" "$start" "$end" "$dry_run" <<'APPLESCRIPT'
on run argv
  set calendarName to item 1 of argv
  set targetEventId to item 2 of argv
  set targetTitle to item 3 of argv
  set startString to item 4 of argv
  set endString to item 5 of argv
  set dryRunValue to item 6 of argv

  tell application "Calendar"
    if targetEventId is not "" then
      set matchedEvents to {}
      repeat with cal in calendars
        set candidateEvents to every event of cal whose id is targetEventId
        if (count of candidateEvents) > 0 then
          set matchedEvents to candidateEvents
          exit repeat
        end if
      end repeat
    else
      if not (exists calendar calendarName) then error "Calendar not found: " & calendarName
      set text item delimiters to {"-", " ", ":"}
      set startParts to text items of startString
      set endParts to text items of endString
      set text item delimiters to ""
      set startDate to current date
      set year of startDate to (item 1 of startParts) as integer
      set month of startDate to (item 2 of startParts) as integer
      set day of startDate to (item 3 of startParts) as integer
      set time of startDate to (((item 4 of startParts) as integer) * hours) + (((item 5 of startParts) as integer) * minutes)
      set endDate to current date
      set year of endDate to (item 1 of endParts) as integer
      set month of endDate to (item 2 of endParts) as integer
      set day of endDate to (item 3 of endParts) as integer
      set time of endDate to (((item 4 of endParts) as integer) * hours) + (((item 5 of endParts) as integer) * minutes)
      set matchedEvents to every event of calendar calendarName whose summary is targetTitle and start date = startDate and end date = endDate
    end if

    set outputText to ""
    repeat with evt in matchedEvents
      set outputText to outputText & (id of evt) & tab & (summary of evt) & linefeed
      if dryRunValue is "0" then delete evt
    end repeat
    return outputText
  end tell
end run
APPLESCRIPT
  )"

  [[ -n "$result" ]] || calendar_die "no matching event found"

  while IFS=$'\t' read -r deleted_id deleted_title; do
    [[ -n "$deleted_id" ]] || continue
    if [[ "$dry_run" -eq 1 ]]; then
      printf 'Matched event: %s [id=%s]\n' "$deleted_title" "$deleted_id"
    else
      printf 'Deleted event: %s [id=%s]\n' "$deleted_title" "$deleted_id"
    fi
  done <<< "$result"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
