#!/usr/bin/env bash

set -euo pipefail

DEFAULT_CALENDAR="个人"
DEFAULT_FORMAT="table"

usage() {
  cat <<'EOF'
Usage:
  listcal [calendar] [start] [end]
  listcal --calendar "<name>" [--start "<YYYY-MM-DD HH:MM>"] [--end "<YYYY-MM-DD HH:MM>"] [--all-calendars] [--format table|tsv]
  listcal --list-calendars

Examples:
  listcal
  listcal "个人"
  listcal "个人" "2026-04-18 00:00" "2026-04-19 00:00"
  listcal --all-calendars --start "2026-04-18 00:00" --end "2026-04-19 00:00" --format tsv
EOF
}

die() {
  printf 'listcal: %s\n' "$1" >&2
  exit 1
}

validate_datetime() {
  local input="$1"
  date -j -f "%Y-%m-%d %H:%M" "$input" "+%s" >/dev/null 2>&1 || \
    die "invalid datetime '$input' (expected YYYY-MM-DD HH:MM)"
}

list_calendars() {
  osascript -e 'tell application "Calendar" to get name of calendars'
}

calendar="$DEFAULT_CALENDAR"
start=""
end=""
all_calendars=0
list_only=0
format="$DEFAULT_FORMAT"

if [[ $# -eq 0 ]]; then
  start="$(date '+%Y-%m-%d 00:00')"
  end="$(date -v+7d '+%Y-%m-%d 00:00')"
fi

if [[ $# -gt 0 && ( "$1" == "--help" || "$1" == "-h" ) ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 && "$1" == --* ]]; then
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --calendar)
        [[ $# -ge 2 ]] || die "missing value for --calendar"
        calendar="$2"
        shift 2
        ;;
      --start)
        [[ $# -ge 2 ]] || die "missing value for --start"
        start="$2"
        shift 2
        ;;
      --end)
        [[ $# -ge 2 ]] || die "missing value for --end"
        end="$2"
        shift 2
        ;;
      --all-calendars)
        all_calendars=1
        shift
        ;;
      --list-calendars)
        list_only=1
        shift
        ;;
      --format)
        [[ $# -ge 2 ]] || die "missing value for --format"
        format="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done
else
  case $# in
    0)
      ;;
    1)
      calendar="$1"
      ;;
    3)
      calendar="$1"
      start="$2"
      end="$3"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
fi

if [[ $list_only -eq 1 ]]; then
  list_calendars
  exit 0
fi

[[ "$format" == "table" || "$format" == "tsv" ]] || die "unsupported format '$format' (use table or tsv)"

if [[ -z "$start" ]]; then
  start="$(date '+%Y-%m-%d 00:00')"
fi

if [[ -z "$end" ]]; then
  end="$(date -j -v+7d -f "%Y-%m-%d %H:%M" "$start" '+%Y-%m-%d %H:%M')"
fi

validate_datetime "$start"
validate_datetime "$end"

start_epoch="$(date -j -f "%Y-%m-%d %H:%M" "$start" "+%s")"
end_epoch="$(date -j -f "%Y-%m-%d %H:%M" "$end" "+%s")"

if [[ "$end_epoch" -le "$start_epoch" ]]; then
  die "end time must be after start time"
fi

raw_output="$(
  osascript \
    -e 'on run argv' \
    -e 'set includeAllCalendars to item 1 of argv' \
    -e 'set selectedCalendar to item 2 of argv' \
    -e 'set startString to item 3 of argv' \
    -e 'set endString to item 4 of argv' \
    -e 'set text item delimiters to {"-", " ", ":"}' \
    -e 'set startParts to text items of startString' \
    -e 'set endParts to text items of endString' \
    -e 'set text item delimiters to ""' \
    -e 'set startDate to current date' \
    -e 'set year of startDate to (item 1 of startParts) as integer' \
    -e 'set month of startDate to (item 2 of startParts) as integer' \
    -e 'set day of startDate to (item 3 of startParts) as integer' \
    -e 'set time of startDate to (((item 4 of startParts) as integer) * hours) + (((item 5 of startParts) as integer) * minutes)' \
    -e 'set endDate to current date' \
    -e 'set year of endDate to (item 1 of endParts) as integer' \
    -e 'set month of endDate to (item 2 of endParts) as integer' \
    -e 'set day of endDate to (item 3 of endParts) as integer' \
    -e 'set time of endDate to (((item 4 of endParts) as integer) * hours) + (((item 5 of endParts) as integer) * minutes)' \
    -e 'set outputLines to {}' \
    -e 'tell application "Calendar"' \
    -e 'if includeAllCalendars is "0" and not (exists calendar selectedCalendar) then error "Calendar not found: " & selectedCalendar' \
    -e 'if includeAllCalendars is "1" then' \
    -e 'set selectedCalendars to every calendar' \
    -e 'else' \
    -e 'set selectedCalendars to {calendar selectedCalendar}' \
    -e 'end if' \
    -e 'repeat with cal in selectedCalendars' \
    -e 'repeat with evt in (every event of cal whose start date < endDate and end date > startDate)' \
    -e 'set lineText to (id of evt) & tab & (name of cal) & tab & (summary of evt) & tab & ((start date of evt) as string) & tab & ((end date of evt) as string)' \
    -e 'set end of outputLines to lineText' \
    -e 'end repeat' \
    -e 'end repeat' \
    -e 'end tell' \
    -e 'set text item delimiters to linefeed' \
    -e 'return outputLines as text' \
    -e 'end run' \
    -- \
    "$all_calendars" "$calendar" "$start" "$end"
)"

if [[ -z "$raw_output" ]]; then
  exit 0
fi

if [[ "$format" == "tsv" ]]; then
  printf 'id\tcalendar\ttitle\tstart\tend\n'
  printf '%s\n' "$raw_output"
  exit 0
fi

while IFS=$'\t' read -r event_id event_calendar event_title event_start event_end; do
  [[ -n "$event_id" ]] || continue
  printf '[%s] %s | %s | %s -> %s\n' \
    "$event_calendar" "$event_title" "$event_id" "$event_start" "$event_end"
done <<< "$raw_output"
