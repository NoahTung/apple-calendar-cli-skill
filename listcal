#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="listcal"

usage() {
  cat <<'EOF'
Usage:
  listcal [calendar] [start] [end]
  listcal --calendar "<name>" [--start "<when>"] [--end "<when>"] [--all-calendars]
          [--format table|tsv|json] [--title-contains "<text>"]
          [--today|--tomorrow|--this-week]
  listcal --list-calendars
EOF
}

query_events() {
  local all_calendars="$1"
  local calendar="$2"
  local title_contains="$3"

  osascript - "$all_calendars" "$calendar" "$title_contains" "$FIELD_DELIM" "$RECORD_DELIM" \
    "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
    "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute" <<'APPLESCRIPT'
on pad2(n)
  if n < 10 then return "0" & (n as text)
  return n as text
end pad2

on replaceText(inputValue, findValue, replaceValue)
  set originalDelims to AppleScript's text item delimiters
  set AppleScript's text item delimiters to findValue
  set parts to every text item of (inputValue as text)
  set AppleScript's text item delimiters to replaceValue
  set normalizedValue to parts as text
  set AppleScript's text item delimiters to originalDelims
  return normalizedValue
end replaceText

on isoDate(theDate)
  set y to year of theDate as integer
  set m to my pad2(month of theDate as integer)
  set d to my pad2(day of theDate as integer)
  set h to my pad2(hours of theDate)
  set minValue to my pad2(minutes of theDate)
  return (y as text) & "-" & m & "-" & d & " " & h & ":" & minValue
end isoDate

on safeText(inputValue, fieldDelim, recordDelim)
  set normalizedValue to inputValue as text
  set normalizedValue to my replaceText(normalizedValue, return, " ")
  set normalizedValue to my replaceText(normalizedValue, linefeed, " ")
  set normalizedValue to my replaceText(normalizedValue, tab, " ")
  set normalizedValue to my replaceText(normalizedValue, fieldDelim, " ")
  set normalizedValue to my replaceText(normalizedValue, recordDelim, " ")
  return normalizedValue
end safeText

on run argv
  set includeAllCalendars to item 1 of argv
  set selectedCalendar to item 2 of argv
  set titleContains to item 3 of argv
  set fieldDelim to item 4 of argv
  set recordDelim to item 5 of argv
  set startYear to (item 6 of argv) as integer
  set startMonth to (item 7 of argv) as integer
  set startDay to (item 8 of argv) as integer
  set startHour to (item 9 of argv) as integer
  set startMinute to (item 10 of argv) as integer
  set endYear to (item 11 of argv) as integer
  set endMonth to (item 12 of argv) as integer
  set endDay to (item 13 of argv) as integer
  set endHour to (item 14 of argv) as integer
  set endMinute to (item 15 of argv) as integer

  set startDate to current date
  set day of startDate to 1
  set year of startDate to startYear
  set month of startDate to startMonth
  set day of startDate to startDay
  set time of startDate to (startHour * hours) + (startMinute * minutes)
  set seconds of startDate to 0

  set endDate to current date
  set day of endDate to 1
  set year of endDate to endYear
  set month of endDate to endMonth
  set day of endDate to endDay
  set time of endDate to (endHour * hours) + (endMinute * minutes)
  set seconds of endDate to 0

  tell application "Calendar"
    if includeAllCalendars is "1" then
      set selectedCalendars to every calendar
    else
      set selectedCalendars to every calendar whose name is selectedCalendar
      if (count of selectedCalendars) is 0 then error "Calendar not found: " & selectedCalendar
    end if

    set outputText to ""

    repeat with cal in selectedCalendars
      repeat with evt in (every event of cal whose start date < endDate and end date > startDate)
        set eventTitle to summary of evt
        if titleContains is "" or eventTitle contains titleContains then
          set alarmValue to ""
          set eventLocation to ""
          set eventNotes to ""
          set eventURL to ""
          if (count of display alarms of evt) > 0 then
            set alarmValue to trigger interval of first display alarm of evt
          end if
          try
            set eventLocation to location of evt
          end try
          try
            set eventNotes to description of evt
          end try
          try
            set eventURL to url of evt
          end try
          set recurrenceValue to ""
          try
            set recurrenceValue to recurrence of evt
          end try
          set allDayValue to "0"
          try
            if allday event of evt then set allDayValue to "1"
          end try
          set recordText to (id of evt) & fieldDelim & (name of cal) & fieldDelim & my safeText(eventTitle, fieldDelim, recordDelim) & fieldDelim & my isoDate(start date of evt) & fieldDelim & my isoDate(end date of evt) & fieldDelim & my safeText(eventLocation, fieldDelim, recordDelim) & fieldDelim & my safeText(eventNotes, fieldDelim, recordDelim) & fieldDelim & my safeText(eventURL, fieldDelim, recordDelim) & fieldDelim & (alarmValue as text) & fieldDelim & my safeText(recurrenceValue, fieldDelim, recordDelim) & fieldDelim & allDayValue
          set outputText to outputText & recordText & recordDelim
        end if
      end repeat
    end repeat

    return outputText
  end tell
end run
APPLESCRIPT
}

main() {
  local calendar="$DEFAULT_CALENDAR"
  local start=""
  local end=""
  local all_calendars=0
  local list_only=0
  local format="$DEFAULT_FORMAT"
  local preset=""
  local title_contains=""

  if [[ $# -eq 0 ]]; then
    {
      IFS= read -r start
      IFS= read -r _
    } < <(compute_range_from_preset today)
    end="$(default_end_from_start "$start")"
  fi

  if [[ $# -gt 0 && ( "$1" == "--help" || "$1" == "-h" ) ]]; then
    usage
    exit 0
  fi

  if [[ $# -gt 0 && "$1" == --* ]]; then
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --calendar)
          [[ $# -ge 2 ]] || calendar_die "missing value for --calendar"
          calendar="$2"
          shift 2
          ;;
        --start)
          [[ $# -ge 2 ]] || calendar_die "missing value for --start"
          start="$2"
          shift 2
          ;;
        --end)
          [[ $# -ge 2 ]] || calendar_die "missing value for --end"
          end="$2"
          shift 2
          ;;
        --all-calendars)
          all_calendars=1
          shift
          ;;
        --list-calendars)
          list_only=1
          shift
          ;;
        --format)
          [[ $# -ge 2 ]] || calendar_die "missing value for --format"
          format="$2"
          shift 2
          ;;
        --title-contains)
          [[ $# -ge 2 ]] || calendar_die "missing value for --title-contains"
          title_contains="$2"
          shift 2
          ;;
        --today|--tomorrow|--this-week)
          [[ -z "$preset" ]] || calendar_die "use only one preset range"
          preset="${1#--}"
          shift
          ;;
        --help|-h)
          usage
          exit 0
          ;;
        *)
          calendar_die "unknown option: $1"
          ;;
      esac
    done
  else
    case $# in
      0)
        ;;
      1)
        calendar="$1"
        ;;
      2)
        calendar="$1"
        start="$2"
        ;;
      3)
        calendar="$1"
        start="$2"
        end="$3"
        ;;
      *)
        usage
        exit 1
        ;;
    esac
  fi

  if [[ $list_only -eq 1 ]]; then
    list_calendars
    exit 0
  fi

  [[ "$format" == "table" || "$format" == "tsv" || "$format" == "json" ]] || calendar_die "unsupported format '$format' (use table, tsv, or json)"

  if [[ -n "$preset" && ( -n "$start" || -n "$end" ) ]]; then
    calendar_die "preset ranges cannot be combined with --start/--end"
  fi

  if [[ -n "$preset" ]]; then
    {
      IFS= read -r start
      IFS= read -r end
    } < <(compute_range_from_preset "$preset")
  fi

  if [[ -z "$start" ]]; then
    {
      IFS= read -r start
      IFS= read -r _
    } < <(compute_range_from_preset today)
  else
    start="$(parse_datetime_expression "$start")"
  fi

  if [[ -z "$end" ]]; then
    end="$(default_end_from_start "$start")"
  else
    end="$(parse_datetime_expression "$end")"
  fi

  parse_datetime "$start" start
  parse_datetime "$end" end
  if [[ "$end_epoch" -le "$start_epoch" ]]; then
    calendar_die "end time must be after start time"
  fi

  local raw_output
  raw_output="$(query_events "$all_calendars" "$calendar" "$title_contains")"

  if [[ -z "$raw_output" ]]; then
    if [[ "$format" == "json" ]]; then
      printf '[]\n'
    fi
    exit 0
  fi

  case "$format" in
    json)
      json_from_records "$raw_output"
      ;;
    tsv)
      printf 'id\tcalendar\ttitle\tstart\tend\tlocation\tnotes\turl\talarm\trecurrence\tall_day\n'
      python3 - "$raw_output" <<'PY'
import sys
field_delim = "\034"
record_delim = "\036"
for raw_record in sys.argv[1].split(record_delim):
    if not raw_record.strip():
        continue
    print(raw_record.replace(field_delim, "\t"))
PY
      ;;
    *)
      event_records_to_table "$raw_output" 0
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
