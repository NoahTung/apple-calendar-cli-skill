#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="editcal"

usage() {
  cat <<'EOF'
Usage:
  editcal --id "<event-id>" [--title "..."] [--start "<when>"] [--end "<when>"] [--calendar "<name>"]
          [--location "..."] [--notes "..."] [--url "..."] [--alarm "<minutes|none>"] [--dry-run]
          [--stdin-json]
EOF
}

main() {
  local event_id=""
  local new_title=""
  local new_start=""
  local new_end=""
  local new_calendar=""
  local new_location=""
  local new_notes=""
  local new_url=""
  local new_alarm_set=0
  local new_alarm=""
  local dry_run=0
  local changed=0
  local stdin_json=0
  local json_payload=""
  local old_record=""
  local new_record=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id)
        [[ $# -ge 2 ]] || calendar_die "missing value for --id"
        event_id="$2"
        shift 2
        ;;
      --title)
        [[ $# -ge 2 ]] || calendar_die "missing value for --title"
        new_title="$2"
        changed=1
        shift 2
        ;;
      --start)
        [[ $# -ge 2 ]] || calendar_die "missing value for --start"
        new_start="$2"
        changed=1
        shift 2
        ;;
      --end)
        [[ $# -ge 2 ]] || calendar_die "missing value for --end"
        new_end="$2"
        changed=1
        shift 2
        ;;
      --calendar)
        [[ $# -ge 2 ]] || calendar_die "missing value for --calendar"
        new_calendar="$2"
        changed=1
        shift 2
        ;;
      --location)
        [[ $# -ge 2 ]] || calendar_die "missing value for --location"
        new_location="$2"
        changed=1
        shift 2
        ;;
      --notes)
        [[ $# -ge 2 ]] || calendar_die "missing value for --notes"
        new_notes="$2"
        changed=1
        shift 2
        ;;
      --url)
        [[ $# -ge 2 ]] || calendar_die "missing value for --url"
        new_url="$2"
        changed=1
        shift 2
        ;;
      --alarm)
        [[ $# -ge 2 ]] || calendar_die "missing value for --alarm"
        new_alarm="$2"
        new_alarm_set=1
        changed=1
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --stdin-json)
        stdin_json=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        calendar_die "unknown option: $1"
        ;;
    esac
  done

  if [[ "$stdin_json" -eq 1 ]]; then
    json_payload="$(cat)"
  fi

  event_id="$(merge_cli_and_json_field "$event_id" "$json_payload" id)"
  new_title="$(merge_cli_and_json_field "$new_title" "$json_payload" title)"
  new_start="$(merge_cli_and_json_field "$new_start" "$json_payload" start)"
  new_end="$(merge_cli_and_json_field "$new_end" "$json_payload" end)"
  new_calendar="$(merge_cli_and_json_field "$new_calendar" "$json_payload" calendar)"
  new_location="$(merge_cli_and_json_field "$new_location" "$json_payload" location)"
  new_notes="$(merge_cli_and_json_field "$new_notes" "$json_payload" notes)"
  new_url="$(merge_cli_and_json_field "$new_url" "$json_payload" url)"

  local json_alarm
  json_alarm="$(json_get_field "$json_payload" alarm)"
  if [[ -n "$json_alarm" ]]; then
    new_alarm="$json_alarm"
    new_alarm_set=1
  fi

  if [[ -n "$new_title" || -n "$new_start" || -n "$new_end" || -n "$new_calendar" || -n "$new_location" || -n "$new_notes" || -n "$new_url" || "$new_alarm_set" -eq 1 ]]; then
    changed=1
  fi

  [[ -n "$event_id" ]] || calendar_die "missing --id"
  [[ "$changed" -eq 1 ]] || calendar_die "provide at least one field to edit"

  if [[ -n "$new_start" ]]; then
    new_start="$(parse_datetime_expression "$new_start")"
  fi
  if [[ -n "$new_end" ]]; then
    new_end="$(parse_datetime_expression "$new_end")"
  fi
  if [[ -n "$new_start" || -n "$new_end" ]]; then
    local compare_start compare_end
    compare_start="${new_start:-1970-01-01 00:00}"
    compare_end="${new_end:-9999-12-31 23:59}"
    parse_datetime "$compare_start" compare_start
    parse_datetime "$compare_end" compare_end
    if [[ -n "$new_start" && -n "$new_end" && "$compare_end_epoch" -le "$compare_start_epoch" ]]; then
      calendar_die "end time must be after start time"
    fi
  fi

  if [[ "$new_alarm_set" -eq 1 ]]; then
    new_alarm="$(normalize_alarm "$new_alarm")"
  fi

  old_record="$(
    osascript - "$event_id" "$FIELD_DELIM" "$RECORD_DELIM" "$new_title" "$new_start" "$new_end" "$new_calendar" "$new_location" "$new_notes" "$new_url" "$new_alarm_set" "$new_alarm" "$dry_run" <<'APPLESCRIPT'
on pad2(n)
  if n < 10 then return "0" & (n as text)
  return n as text
end pad2

on replaceText(inputValue, findValue, replaceValue)
  set originalDelims to AppleScript's text item delimiters
  set AppleScript's text item delimiters to findValue
  set parts to every text item of (inputValue as text)
  set AppleScript's text item delimiters to replaceValue
  set normalizedValue to parts as text
  set AppleScript's text item delimiters to originalDelims
  return normalizedValue
end replaceText

on isoDate(theDate)
  set y to year of theDate as integer
  set m to my pad2(month of theDate as integer)
  set d to my pad2(day of theDate as integer)
  set h to my pad2(hours of theDate)
  set minValue to my pad2(minutes of theDate)
  return (y as text) & "-" & m & "-" & d & " " & h & ":" & minValue
end isoDate

on safeText(inputValue, fieldDelim, recordDelim)
  set normalizedValue to inputValue as text
  set normalizedValue to my replaceText(normalizedValue, return, " ")
  set normalizedValue to my replaceText(normalizedValue, linefeed, " ")
  set normalizedValue to my replaceText(normalizedValue, tab, " ")
  set normalizedValue to my replaceText(normalizedValue, fieldDelim, " ")
  set normalizedValue to my replaceText(normalizedValue, recordDelim, " ")
  return normalizedValue
end safeText

on eventRecord(evt, calName, fieldDelim, recordDelim)
  set alarmValue to ""
  set eventLocation to ""
  set eventNotes to ""
  set eventURL to ""
  if (count of display alarms of evt) > 0 then
    set alarmValue to trigger interval of first display alarm of evt
  end if
  try
    set eventLocation to location of evt
  end try
  try
    set eventNotes to description of evt
  end try
  try
    set eventURL to url of evt
  end try
  set recurrenceValue to ""
  try
    set recurrenceValue to recurrence of evt
  end try
  return (id of evt) & fieldDelim & calName & fieldDelim & my safeText(summary of evt, fieldDelim, recordDelim) & fieldDelim & my isoDate(start date of evt) & fieldDelim & my isoDate(end date of evt) & fieldDelim & my safeText(eventLocation, fieldDelim, recordDelim) & fieldDelim & my safeText(eventNotes, fieldDelim, recordDelim) & fieldDelim & my safeText(eventURL, fieldDelim, recordDelim) & fieldDelim & (alarmValue as text) & fieldDelim & my safeText(recurrenceValue, fieldDelim, recordDelim) & recordDelim
end eventRecord

on run argv
  set targetEventId to item 1 of argv
  set fieldDelim to item 2 of argv
  set recordDelim to item 3 of argv
  set newTitle to item 4 of argv
  set newStartString to item 5 of argv
  set newEndString to item 6 of argv
  set newCalendarName to item 7 of argv
  set newLocation to item 8 of argv
  set newNotes to item 9 of argv
  set newURL to item 10 of argv
  set alarmSet to item 11 of argv
  set newAlarm to item 12 of argv
  set dryRunValue to item 13 of argv

  tell application "Calendar"
    set foundCalendar to missing value
    set foundEvent to missing value
    repeat with cal in calendars
      set candidateEvents to every event of cal whose id is targetEventId
      if (count of candidateEvents) > 0 then
        set foundCalendar to cal
        set foundEvent to item 1 of candidateEvents
        exit repeat
      end if
    end repeat

    if foundEvent is missing value then error "Event not found: " & targetEventId

    set oldRecordText to my eventRecord(foundEvent, name of foundCalendar, fieldDelim, recordDelim)

    set effectiveTitle to summary of foundEvent
    set effectiveStart to start date of foundEvent
    set effectiveEnd to end date of foundEvent
    set effectiveLocation to location of foundEvent
    set effectiveNotes to description of foundEvent
    set effectiveURL to url of foundEvent
    set effectiveRecurrence to ""
    try
      set effectiveRecurrence to recurrence of foundEvent
    end try
    set targetCalendar to foundCalendar

    if newTitle is not "" then set effectiveTitle to newTitle
    if newStartString is not "" then
      set text item delimiters to {"-", " ", ":"}
      set startParts to text items of newStartString
      set text item delimiters to ""
      set effectiveStart to current date
      set day of effectiveStart to 1
      set year of effectiveStart to (item 1 of startParts) as integer
      set month of effectiveStart to (item 2 of startParts) as integer
      set day of effectiveStart to (item 3 of startParts) as integer
      set time of effectiveStart to (((item 4 of startParts) as integer) * hours) + (((item 5 of startParts) as integer) * minutes)
      set seconds of effectiveStart to 0
    end if
    if newEndString is not "" then
      set text item delimiters to {"-", " ", ":"}
      set endParts to text items of newEndString
      set text item delimiters to ""
      set effectiveEnd to current date
      set day of effectiveEnd to 1
      set year of effectiveEnd to (item 1 of endParts) as integer
      set month of effectiveEnd to (item 2 of endParts) as integer
      set day of effectiveEnd to (item 3 of endParts) as integer
      set time of effectiveEnd to (((item 4 of endParts) as integer) * hours) + (((item 5 of endParts) as integer) * minutes)
      set seconds of effectiveEnd to 0
    end if
    if newLocation is not "" then set effectiveLocation to newLocation
    if newNotes is not "" then set effectiveNotes to newNotes
    if newURL is not "" then set effectiveURL to newURL

    if newCalendarName is not "" then
      set targetCalendars to every calendar whose name is newCalendarName
      if (count of targetCalendars) is 0 then error "Calendar not found: " & newCalendarName
      set targetCalendar to first item of targetCalendars
    end if

    if dryRunValue is "0" then
      if (name of targetCalendar) is (name of foundCalendar) then
        set summary of foundEvent to effectiveTitle
        set start date of foundEvent to effectiveStart
        set end date of foundEvent to effectiveEnd
        set location of foundEvent to effectiveLocation
        set description of foundEvent to effectiveNotes
        set url of foundEvent to effectiveURL

        if alarmSet is "1" then
          repeat with existingAlarm in display alarms of foundEvent
            delete existingAlarm
          end repeat
          if newAlarm is not "none" and newAlarm is not "" then
            tell foundEvent
              make new display alarm at end of display alarms with properties {trigger interval:(-1 * (newAlarm as integer))}
            end tell
          end if
        end if
      else
        tell targetCalendar
          set clonedEvent to make new event with properties {summary:effectiveTitle, start date:effectiveStart, end date:effectiveEnd}
        end tell
        set location of clonedEvent to effectiveLocation
        set description of clonedEvent to effectiveNotes
        set url of clonedEvent to effectiveURL
        if effectiveRecurrence is not "" then set recurrence of clonedEvent to effectiveRecurrence
        if alarmSet is "1" then
          if newAlarm is not "none" and newAlarm is not "" then
            tell clonedEvent
              make new display alarm at end of display alarms with properties {trigger interval:(-1 * (newAlarm as integer))}
            end tell
          end if
        else if (count of display alarms of foundEvent) > 0 then
          tell clonedEvent
            make new display alarm at end of display alarms with properties {trigger interval:(trigger interval of first display alarm of foundEvent)}
          end tell
        end if
        delete foundEvent
        set foundEvent to clonedEvent
        set foundCalendar to targetCalendar
      end if
    else
      if newCalendarName is not "" then set foundCalendar to targetCalendar
    end if

    if dryRunValue is "1" then
      set shadowEventTitle to effectiveTitle
      set shadowStart to effectiveStart
      set shadowEnd to effectiveEnd
      set shadowLocation to effectiveLocation
      set shadowNotes to effectiveNotes
      set shadowURL to effectiveURL
      set alarmValue to ""
      if alarmSet is "1" then
        if newAlarm is not "none" then set alarmValue to "-" & newAlarm
      else if (count of display alarms of foundEvent) > 0 then
        set alarmValue to trigger interval of first display alarm of foundEvent
      end if
      set newRecordText to targetEventId & fieldDelim & (name of foundCalendar) & fieldDelim & my safeText(shadowEventTitle, fieldDelim, recordDelim) & fieldDelim & my isoDate(shadowStart) & fieldDelim & my isoDate(shadowEnd) & fieldDelim & my safeText(shadowLocation, fieldDelim, recordDelim) & fieldDelim & my safeText(shadowNotes, fieldDelim, recordDelim) & fieldDelim & my safeText(shadowURL, fieldDelim, recordDelim) & fieldDelim & (alarmValue as text) & fieldDelim & my safeText(effectiveRecurrence, fieldDelim, recordDelim) & recordDelim
    else
      set newRecordText to my eventRecord(foundEvent, name of foundCalendar, fieldDelim, recordDelim)
    end if

    return oldRecordText & newRecordText
  end tell
end run
APPLESCRIPT
  )"

  local combined_records="$old_record"
  old_record="$(python3 - "$combined_records" <<'PY'
import sys
parts = [part for part in sys.argv[1].split("\036") if part]
print((parts[0] if parts else "") + ("\036" if parts else ""), end="")
PY
)"
  new_record="$(python3 - "$combined_records" <<'PY'
import sys
parts = [part for part in sys.argv[1].split("\036") if part]
print((parts[1] if len(parts) > 1 else "") + ("\036" if len(parts) > 1 else ""), end="")
PY
)"

  printf 'Old:\n'
  event_records_to_table "$old_record" 1
  printf 'New:\n'
  event_records_to_table "$new_record" 1
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
