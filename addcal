#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="addcal"

usage() {
  cat <<'EOF'
Usage:
  addcal [calendar] <start> <end> <title>
  addcal --start "<when>" --end "<when>" --title "<title>" [--calendar "<name>"] [--bucket personal|work|life]
         [--location "<location>"] [--notes "<notes>"] [--url "<url>"] [--alarm "<minutes|none>"]
         [--repeat "<daily|weekly|monthly|yearly|weekly 1,3,5>"] [--rrule "<recurrence>"]
         [--check-conflict] [--no-check-conflict] [--all-day] [--stdin-json]
  addcal --list-calendars

Examples:
  addcal "2026-04-18 19:00" "2026-04-18 20:00" "吃饭"
  addcal --bucket work --start "tomorrow 9am" --end "tomorrow 10am" --title "Standup" --alarm "15"
  addcal --calendar "个人" --start "+2h" --end "+3h" --title "海底捞晚饭" --location "万达广场3楼" --notes "已订位"
  addcal --start "2026-04-18 18:00" --end "2026-04-18 19:00" --title "Gym" --repeat "weekly 1,3,5"
  echo '{"calendar":"Personal","title":"Dinner","start":"2026-04-20 19:00","end":"2026-04-20 20:00","notes":"Booked"}' | addcal --stdin-json
EOF
}

check_conflicts() {
  local calendar="$1"
  local start_year="$2"
  local start_month="$3"
  local start_day="$4"
  local start_hour="$5"
  local start_minute="$6"
  local end_year="$7"
  local end_month="$8"
  local end_day="$9"
  local end_hour="${10}"
  local end_minute="${11}"

  osascript - "$calendar" "$FIELD_DELIM" "$RECORD_DELIM" \
    "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
    "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute" <<'APPLESCRIPT'
on pad2(n)
  if n < 10 then return "0" & (n as text)
  return n as text
end pad2

on replaceText(inputValue, findValue, replaceValue)
  set originalDelims to AppleScript's text item delimiters
  set AppleScript's text item delimiters to findValue
  set parts to every text item of (inputValue as text)
  set AppleScript's text item delimiters to replaceValue
  set normalizedValue to parts as text
  set AppleScript's text item delimiters to originalDelims
  return normalizedValue
end replaceText

on isoDate(theDate)
  set y to year of theDate as integer
  set m to my pad2(month of theDate as integer)
  set d to my pad2(day of theDate as integer)
  set h to my pad2(hours of theDate)
  set minValue to my pad2(minutes of theDate)
  return (y as text) & "-" & m & "-" & d & " " & h & ":" & minValue
end isoDate

on safeText(inputValue, fieldDelim, recordDelim)
  set normalizedValue to inputValue as text
  set normalizedValue to my replaceText(normalizedValue, return, " ")
  set normalizedValue to my replaceText(normalizedValue, linefeed, " ")
  set normalizedValue to my replaceText(normalizedValue, tab, " ")
  set normalizedValue to my replaceText(normalizedValue, fieldDelim, " ")
  set normalizedValue to my replaceText(normalizedValue, recordDelim, " ")
  return normalizedValue
end safeText

on run argv
  set calendarName to item 1 of argv
  set fieldDelim to item 2 of argv
  set recordDelim to item 3 of argv
  set startYear to (item 4 of argv) as integer
  set startMonth to (item 5 of argv) as integer
  set startDay to (item 6 of argv) as integer
  set startHour to (item 7 of argv) as integer
  set startMinute to (item 8 of argv) as integer
  set endYear to (item 9 of argv) as integer
  set endMonth to (item 10 of argv) as integer
  set endDay to (item 11 of argv) as integer
  set endHour to (item 12 of argv) as integer
  set endMinute to (item 13 of argv) as integer

  set startDate to current date
  set day of startDate to 1
  set year of startDate to startYear
  set month of startDate to startMonth
  set day of startDate to startDay
  set time of startDate to (startHour * hours) + (startMinute * minutes)
  set seconds of startDate to 0

  set endDate to current date
  set day of endDate to 1
  set year of endDate to endYear
  set month of endDate to endMonth
  set day of endDate to endDay
  set time of endDate to (endHour * hours) + (endMinute * minutes)
  set seconds of endDate to 0

  tell application "Calendar"
    set matchingCalendars to every calendar whose name is calendarName
    if (count of matchingCalendars) is 0 then error "Calendar not found: " & calendarName
    set cal to first item of matchingCalendars
    set outputText to ""

    repeat with evt in (every event of cal whose start date < endDate and end date > startDate)
      set alarmValue to ""
      set eventLocation to ""
      set eventNotes to ""
      set eventURL to ""
      if (count of display alarms of evt) > 0 then
        set alarmValue to trigger interval of first display alarm of evt
      end if
      try
        set eventLocation to location of evt
      end try
      try
        set eventNotes to description of evt
      end try
      try
        set eventURL to url of evt
      end try
      set recurrenceValue to ""
      try
        set recurrenceValue to recurrence of evt
      end try
      set recordText to (id of evt) & fieldDelim & (name of cal) & fieldDelim & my safeText(summary of evt, fieldDelim, recordDelim) & fieldDelim & my isoDate(start date of evt) & fieldDelim & my isoDate(end date of evt) & fieldDelim & my safeText(eventLocation, fieldDelim, recordDelim) & fieldDelim & my safeText(eventNotes, fieldDelim, recordDelim) & fieldDelim & my safeText(eventURL, fieldDelim, recordDelim) & fieldDelim & (alarmValue as text) & fieldDelim & my safeText(recurrenceValue, fieldDelim, recordDelim)
      set outputText to outputText & recordText & recordDelim
    end repeat

    return outputText
  end tell
end run
APPLESCRIPT
}

main() {
  local calendar="$DEFAULT_CALENDAR"
  local start=""
  local end=""
  local title=""
  local bucket=""
  local location=""
  local notes=""
  local url=""
  local alarm=""
  local repeat_spec=""
  local rrule=""
  local recurrence=""
  local list_only=0
  local explicit_calendar=0
  local check_conflict=1
  local no_check_conflict=0
  local all_day=0
  local stdin_json=0
  local json_payload=""
  local normalized_bucket=""
  local routing_note=""
  local event_id=""
  local conflicts=""
  local conflict_count=0

  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    usage
    exit 0
  fi

  if [[ "$1" == --* ]]; then
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --calendar)
          [[ $# -ge 2 ]] || calendar_die "missing value for --calendar"
          calendar="$2"
          explicit_calendar=1
          shift 2
          ;;
        --bucket)
          [[ $# -ge 2 ]] || calendar_die "missing value for --bucket"
          bucket="$2"
          shift 2
          ;;
        --start)
          [[ $# -ge 2 ]] || calendar_die "missing value for --start"
          start="$2"
          shift 2
          ;;
        --end)
          [[ $# -ge 2 ]] || calendar_die "missing value for --end"
          end="$2"
          shift 2
          ;;
        --title)
          [[ $# -ge 2 ]] || calendar_die "missing value for --title"
          title="$2"
          shift 2
          ;;
        --location)
          [[ $# -ge 2 ]] || calendar_die "missing value for --location"
          location="$2"
          shift 2
          ;;
        --notes)
          [[ $# -ge 2 ]] || calendar_die "missing value for --notes"
          notes="$2"
          shift 2
          ;;
        --url)
          [[ $# -ge 2 ]] || calendar_die "missing value for --url"
          url="$2"
          shift 2
          ;;
        --alarm)
          [[ $# -ge 2 ]] || calendar_die "missing value for --alarm"
          alarm="$2"
          shift 2
          ;;
        --repeat)
          [[ $# -ge 2 ]] || calendar_die "missing value for --repeat"
          repeat_spec="$2"
          shift 2
          ;;
        --rrule)
          [[ $# -ge 2 ]] || calendar_die "missing value for --rrule"
          rrule="$2"
          shift 2
          ;;
        --check-conflict)
          check_conflict=1
          shift
          ;;
        --no-check-conflict)
          no_check_conflict=1
          shift
          ;;
        --all-day)
          all_day=1
          shift
          ;;
        --stdin-json)
          stdin_json=1
          shift
          ;;
        --list-calendars)
          list_only=1
          shift
          ;;
        --help|-h)
          usage
          exit 0
          ;;
        *)
          calendar_die "unknown option: $1"
          ;;
      esac
    done
  else
    case $# in
      3)
        start="$1"
        end="$2"
        title="$3"
        ;;
      4)
        calendar="$1"
        explicit_calendar=1
        start="$2"
        end="$3"
        title="$4"
        ;;
      *)
        usage
        exit 1
        ;;
    esac
  fi

  if [[ "$stdin_json" -eq 1 ]]; then
    json_payload="$(cat)"
  fi

  calendar="$(merge_cli_and_json_field "$calendar" "$json_payload" calendar)"
  title="$(merge_cli_and_json_field "$title" "$json_payload" title)"
  start="$(merge_cli_and_json_field "$start" "$json_payload" start)"
  end="$(merge_cli_and_json_field "$end" "$json_payload" end)"
  location="$(merge_cli_and_json_field "$location" "$json_payload" location)"
  notes="$(merge_cli_and_json_field "$notes" "$json_payload" notes)"
  url="$(merge_cli_and_json_field "$url" "$json_payload" url)"
  alarm="$(merge_cli_and_json_field "$alarm" "$json_payload" alarm)"
  repeat_spec="$(merge_cli_and_json_field "$repeat_spec" "$json_payload" repeat)"
  rrule="$(merge_cli_and_json_field "$rrule" "$json_payload" rrule)"

  if [[ "$no_check_conflict" -eq 1 ]]; then
    check_conflict=0
  fi

  local json_all_day
  json_all_day="$(json_get_field "$json_payload" all_day)"
  if [[ "$json_all_day" == "true" || "$json_all_day" == "1" ]]; then
    all_day=1
  fi

  if [[ $list_only -eq 1 ]]; then
    list_calendars
    exit 0
  fi

  [[ -n "$start" ]] || calendar_die "missing start time"
  [[ -n "$title" ]] || calendar_die "missing title"

  if [[ "$all_day" -eq 1 ]]; then
    start="$(normalize_date_input "$start")"
    if [[ -z "$end" ]]; then
      end="$(infer_all_day_end "$start")"
    else
      end="$(normalize_date_input "$end")"
    fi
  fi

  [[ -n "$end" ]] || calendar_die "missing end time"

  if [[ -n "$bucket" && "$explicit_calendar" -eq 0 ]]; then
    normalized_bucket="$(normalize_bucket "$bucket")"
  fi

  calendar="$(select_calendar "$calendar" "$bucket" "$explicit_calendar")"
  if [[ -n "$normalized_bucket" ]]; then
    routing_note=" (bucket ${normalized_bucket} -> ${calendar})"
  fi

  parse_datetime "$start" start
  parse_datetime "$end" end

  if [[ "$end_epoch" -le "$start_epoch" ]]; then
    calendar_die "end time must be after start time"
  fi

  alarm="$(normalize_alarm "$alarm")"
  recurrence="$(resolve_recurrence_input "$repeat_spec" "$rrule")"

  if [[ "$check_conflict" -eq 1 ]]; then
    conflicts="$(check_conflicts "$calendar" \
      "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
      "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute")"
    if [[ -n "$conflicts" ]]; then
      conflict_count="$(count_records "$conflicts")"
      printf 'Warning: %s overlapping event(s) in %s\n' "$conflict_count" "$calendar" >&2
      event_records_to_table "$conflicts" 0 >&2
    fi
  fi

  event_id="$(
    osascript - "$calendar" "$title" "$location" "$notes" "$url" "$alarm" "$recurrence" "$all_day" \
      "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
      "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute" <<'APPLESCRIPT'
on run argv
  set calendarName to item 1 of argv
  set eventTitle to item 2 of argv
  set locationValue to item 3 of argv
  set notesValue to item 4 of argv
  set urlValue to item 5 of argv
  set alarmValue to item 6 of argv
  set recurrenceValue to item 7 of argv
  set allDayValue to item 8 of argv
  set startYear to (item 9 of argv) as integer
  set startMonth to (item 10 of argv) as integer
  set startDay to (item 11 of argv) as integer
  set startHour to (item 12 of argv) as integer
  set startMinute to (item 13 of argv) as integer
  set endYear to (item 14 of argv) as integer
  set endMonth to (item 15 of argv) as integer
  set endDay to (item 16 of argv) as integer
  set endHour to (item 17 of argv) as integer
  set endMinute to (item 18 of argv) as integer

  set startDate to current date
  set day of startDate to 1
  set year of startDate to startYear
  set month of startDate to startMonth
  set day of startDate to startDay
  set time of startDate to (startHour * hours) + (startMinute * minutes)
  set seconds of startDate to 0

  set endDate to current date
  set day of endDate to 1
  set year of endDate to endYear
  set month of endDate to endMonth
  set day of endDate to endDay
  set time of endDate to (endHour * hours) + (endMinute * minutes)
  set seconds of endDate to 0

  tell application "Calendar"
    set matchingCalendars to every calendar whose name is calendarName
    if (count of matchingCalendars) is 0 then error "Calendar not found: " & calendarName
    tell first item of matchingCalendars
      if allDayValue is "1" then
        set newEvent to make new event with properties {summary:eventTitle, start date:startDate, end date:endDate, allday event:true}
      else
        set newEvent to make new event with properties {summary:eventTitle, start date:startDate, end date:endDate}
      end if
      if locationValue is not "" then set location of newEvent to locationValue
      if notesValue is not "" then set description of newEvent to notesValue
      if urlValue is not "" then set url of newEvent to urlValue
      if recurrenceValue is not "" then set recurrence of newEvent to recurrenceValue
      if alarmValue is not "" and alarmValue is not "none" then
        tell newEvent
          make new display alarm at end of display alarms with properties {trigger interval:(-1 * (alarmValue as integer))}
        end tell
      end if
      return id of newEvent
    end tell
  end tell
end run
APPLESCRIPT
  )"

  printf 'Created event in %s%s: %s (%s -> %s) [id=%s]\n' \
    "$calendar" "$routing_note" "$title" "$start_normalized" "$end_normalized" "$event_id"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
