#!/usr/bin/env bash

set -euo pipefail

DEFAULT_CALENDAR="个人"

usage() {
  cat <<'EOF'
Usage:
  addcal [calendar] <start> <end> <title>
  addcal --start "<YYYY-MM-DD HH:MM>" --end "<YYYY-MM-DD HH:MM>" --title "<title>" [--calendar "<name>"]
  addcal --list-calendars

Examples:
  addcal "2026-04-18 19:00" "2026-04-18 20:00" "吃饭"
  addcal "工作" "2026-04-18 17:00" "2026-04-18 18:00" "专注工作"
  addcal --calendar "个人" --start "2026-04-18 19:00" --end "2026-04-18 20:00" --title "吃饭"
EOF
}

die() {
  printf 'addcal: %s\n' "$1" >&2
  exit 1
}

validate_datetime() {
  local input="$1"
  date -j -f "%Y-%m-%d %H:%M" "$input" "+%s" >/dev/null 2>&1 || \
    die "invalid datetime '$input' (expected YYYY-MM-DD HH:MM)"
}

parse_datetime() {
  local input="$1"
  local prefix="$2"

  validate_datetime "$input"

  [[ "$input" =~ ^([0-9]{4})-([0-9]{2})-([0-9]{2})[[:space:]]([0-9]{2}):([0-9]{2})$ ]] || \
    die "invalid datetime '$input' (expected YYYY-MM-DD HH:MM)"

  printf -v "${prefix}_year" '%d' "${BASH_REMATCH[1]}"
  printf -v "${prefix}_month" '%d' "${BASH_REMATCH[2]}"
  printf -v "${prefix}_day" '%d' "${BASH_REMATCH[3]}"
  printf -v "${prefix}_hour" '%d' "${BASH_REMATCH[4]}"
  printf -v "${prefix}_minute" '%d' "${BASH_REMATCH[5]}"
  printf -v "${prefix}_epoch" '%s' "$(date -j -f "%Y-%m-%d %H:%M" "$input" "+%s")"
}

list_calendars() {
  osascript -e 'tell application "Calendar" to get name of calendars'
}

calendar="$DEFAULT_CALENDAR"
start=""
end=""
title=""
list_only=0

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "$1" == --* ]]; then
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --calendar)
        [[ $# -ge 2 ]] || die "missing value for --calendar"
        calendar="$2"
        shift 2
        ;;
      --start)
        [[ $# -ge 2 ]] || die "missing value for --start"
        start="$2"
        shift 2
        ;;
      --end)
        [[ $# -ge 2 ]] || die "missing value for --end"
        end="$2"
        shift 2
        ;;
      --title)
        [[ $# -ge 2 ]] || die "missing value for --title"
        title="$2"
        shift 2
        ;;
      --list-calendars)
        list_only=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done
else
  case $# in
    3)
      start="$1"
      end="$2"
      title="$3"
      ;;
    4)
      calendar="$1"
      start="$2"
      end="$3"
      title="$4"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
fi

if [[ $list_only -eq 1 ]]; then
  list_calendars
  exit 0
fi

[[ -n "$start" ]] || die "missing start time"
[[ -n "$end" ]] || die "missing end time"
[[ -n "$title" ]] || die "missing title"

parse_datetime "$start" start
parse_datetime "$end" end

if [[ "$end_epoch" -le "$start_epoch" ]]; then
  die "end time must be after start time"
fi

event_id="$(
  osascript \
    -e 'on run argv' \
    -e 'set calendarName to item 1 of argv' \
    -e 'set eventTitle to item 2 of argv' \
    -e 'set startYear to (item 3 of argv) as integer' \
    -e 'set startMonth to (item 4 of argv) as integer' \
    -e 'set startDay to (item 5 of argv) as integer' \
    -e 'set startHour to (item 6 of argv) as integer' \
    -e 'set startMinute to (item 7 of argv) as integer' \
    -e 'set endYear to (item 8 of argv) as integer' \
    -e 'set endMonth to (item 9 of argv) as integer' \
    -e 'set endDay to (item 10 of argv) as integer' \
    -e 'set endHour to (item 11 of argv) as integer' \
    -e 'set endMinute to (item 12 of argv) as integer' \
    -e 'tell application "Calendar"' \
    -e 'if not (exists calendar calendarName) then error "Calendar not found: " & calendarName' \
    -e 'set startDate to current date' \
    -e 'set year of startDate to startYear' \
    -e 'set month of startDate to startMonth' \
    -e 'set day of startDate to startDay' \
    -e 'set time of startDate to (startHour * hours) + (startMinute * minutes)' \
    -e 'set endDate to current date' \
    -e 'set year of endDate to endYear' \
    -e 'set month of endDate to endMonth' \
    -e 'set day of endDate to endDay' \
    -e 'set time of endDate to (endHour * hours) + (endMinute * minutes)' \
    -e 'tell calendar calendarName' \
    -e 'set newEvent to make new event with properties {summary:eventTitle, start date:startDate, end date:endDate}' \
    -e 'set newEventId to id of newEvent' \
    -e 'end tell' \
    -e 'end tell' \
    -e 'return newEventId' \
    -e 'end run' \
    -- \
    "$calendar" \
    "$title" \
    "$start_year" "$start_month" "$start_day" "$start_hour" "$start_minute" \
    "$end_year" "$end_month" "$end_day" "$end_hour" "$end_minute"
)"

printf 'Created event in %s: %s (%s -> %s) [id=%s]\n' \
  "$calendar" "$title" "$start" "$end" "$event_id"
