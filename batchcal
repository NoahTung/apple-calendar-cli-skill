#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$repo_root/calendar-lib.sh"

CALENDAR_CMD_NAME="batchcal"

usage() {
  cat <<'EOF'
Usage:
  batchcal --plan <file.json> --dry-run
  batchcal --plan <file.json> --apply
  batchcal --stdin --dry-run
  batchcal --stdin --apply
EOF
}

load_plan() {
  local mode="$1"
  local input="$2"

  if [[ "$mode" == "file" ]]; then
    [[ -f "$input" ]] || calendar_die "plan file not found: $input"
    cat "$input"
  else
    cat
  fi
}

normalize_plan() {
  local raw_json="$1"

  python3 - "$raw_json" <<'PY' || exit 1
import json
import sys

raw_json = sys.argv[1]
plan = json.loads(raw_json)

defaults = {
    "calendar": plan.get("calendar", ""),
    "bucket": plan.get("bucket", ""),
    "timezone": plan.get("timezone", ""),
    "mode": plan.get("mode", ""),
}
events = plan.get("events")
if not isinstance(events, list) or not events:
    raise SystemExit("batchcal: plan must contain a non-empty events array")

normalized = []
for index, event in enumerate(events, start=1):
    if not isinstance(event, dict):
        raise SystemExit(f"batchcal: event #{index} must be an object")
    merged = defaults | event
    event_type = merged.get("type", "single")
    title = merged.get("title", "")
    if not title:
        raise SystemExit(f"batchcal: event #{index} is missing title")
    start = merged.get("start", "")
    end = merged.get("end", "")
    if not start or not end:
        raise SystemExit(f"batchcal: event #{index} is missing start/end")
    if event_type not in {"single", "recurring"}:
        raise SystemExit(f"batchcal: event #{index} has unsupported type '{event_type}'")
    recurrence = merged.get("recurrence", "")
    if event_type == "recurring" and not recurrence:
        raise SystemExit(f"batchcal: event #{index} is missing recurrence")
    normalized.append({
        "index": index,
        "type": event_type,
        "title": title,
        "start": start,
        "end": end,
        "calendar": merged.get("calendar", ""),
        "bucket": merged.get("bucket", ""),
        "location": merged.get("location", ""),
        "notes": merged.get("notes", ""),
        "url": merged.get("url", ""),
        "alarm": merged.get("alarm", ""),
        "repeat": recurrence,
        "source_key": merged.get("source_key", ""),
    })

print(json.dumps(normalized, ensure_ascii=False))
PY
}

iter_plan_items() {
  local normalized_json="$1"

  python3 - "$normalized_json" <<'PY'
import json
import sys

for item in json.loads(sys.argv[1]):
    print(json.dumps(item, ensure_ascii=False))
PY
}

read_plan_item_fields() {
  local item_json="$1"

  {
    IFS= read -r -d '' plan_index
    IFS= read -r -d '' plan_type
    IFS= read -r -d '' plan_title
    IFS= read -r -d '' plan_start
    IFS= read -r -d '' plan_end
    IFS= read -r -d '' plan_calendar
    IFS= read -r -d '' plan_bucket
    IFS= read -r -d '' plan_location
    IFS= read -r -d '' plan_notes
    IFS= read -r -d '' plan_url
    IFS= read -r -d '' plan_alarm
    IFS= read -r -d '' plan_repeat
    IFS= read -r -d '' plan_source_key
    IFS= read -r -d '' plan_timezone
  } < <(
    python3 - "$item_json" <<'PY'
import json
import sys

item = json.loads(sys.argv[1])
fields = [
    str(item.get("index", "")),
    item.get("type", ""),
    item.get("title", ""),
    item.get("start", ""),
    item.get("end", ""),
    item.get("calendar", ""),
    item.get("bucket", ""),
    item.get("location", ""),
    item.get("notes", ""),
    item.get("url", ""),
    item.get("alarm", ""),
    item.get("repeat", ""),
    item.get("source_key", ""),
    item.get("timezone", ""),
]
for value in fields:
    sys.stdout.write((value if value is not None else "") + "\0")
PY
  )
}

validate_plan_items() {
  local normalized_json="$1"
  local item_json=""

  while IFS= read -r item_json; do
    [[ -n "$item_json" ]] || continue
    read_plan_item_fields "$item_json"
    parse_datetime_expression "$plan_start" >/dev/null
    parse_datetime_expression "$plan_end" >/dev/null
    if [[ -n "$plan_repeat" ]]; then
      normalize_repeat "$plan_repeat" >/dev/null
    fi
  done < <(iter_plan_items "$normalized_json")
}

main() {
  local input_mode=""
  local plan_file=""
  local do_apply=0
  local do_dry_run=0
  local raw_json=""
  local normalized_json=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --plan)
        [[ $# -ge 2 ]] || calendar_die "missing value for --plan"
        input_mode="file"
        plan_file="$2"
        shift 2
        ;;
      --stdin)
        input_mode="stdin"
        shift
        ;;
      --dry-run)
        do_dry_run=1
        shift
        ;;
      --apply)
        do_apply=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        calendar_die "unknown option: $1"
        ;;
    esac
  done

  [[ -n "$input_mode" ]] || calendar_die "choose --plan or --stdin"
  [[ $((do_apply + do_dry_run)) -eq 1 ]] || calendar_die "choose exactly one of --dry-run or --apply"

  if [[ "$input_mode" == "file" ]]; then
    raw_json="$(load_plan file "$plan_file")"
  else
    raw_json="$(load_plan stdin "")"
  fi
  normalized_json="$(normalize_plan "$raw_json")"
  validate_plan_items "$normalized_json"

  if [[ "$do_dry_run" -eq 1 ]]; then
    python3 - "$normalized_json" <<'PY'
import json
import sys
items = json.loads(sys.argv[1])
print(f"Planned events: {len(items)}")
for item in items:
    destination = item["calendar"] or f"bucket:{item['bucket']}" if item["bucket"] else "(default)"
    print(f"- #{item['index']} {item['type']} | {item['title']} | {item['start']} -> {item['end']} | {destination}")
    if item["repeat"]:
        print(f"  recurrence: {item['repeat']}")
    if item["source_key"]:
        print(f"  source_key: {item['source_key']}")
PY
    exit 0
  fi

  while IFS= read -r item_json; do
    [[ -n "$item_json" ]] || continue
    read_plan_item_fields "$item_json"

    cmd=("$repo_root/addcal" --start "$plan_start" --end "$plan_end" --title "$plan_title")
    [[ -n "$plan_calendar" ]] && cmd+=(--calendar "$plan_calendar")
    [[ -n "$plan_bucket" ]] && cmd+=(--bucket "$plan_bucket")
    [[ -n "$plan_location" ]] && cmd+=(--location "$plan_location")
    [[ -n "$plan_notes" ]] && cmd+=(--notes "$plan_notes")
    [[ -n "$plan_url" ]] && cmd+=(--url "$plan_url")
    [[ -n "$plan_alarm" ]] && cmd+=(--alarm "$plan_alarm")
    [[ -n "$plan_repeat" ]] && cmd+=(--repeat "$plan_repeat")
    "${cmd[@]}"
  done < <(iter_plan_items "$normalized_json")
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
